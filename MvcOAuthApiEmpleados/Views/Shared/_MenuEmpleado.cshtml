@if (Context.User.Identity.IsAuthenticated == true)
{
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="" asp-controller="Empleados" asp-action="Index">Empleados</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="" asp-controller="Empleados" asp-action="Compis">Compis</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="" asp-controller="Empleados" asp-action="PerfilEmpleado">Perfil</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-danger" asp-area="" asp-controller="Managed" asp-action="LogOut">Log Out @Context.User.Identity.Name</a>
